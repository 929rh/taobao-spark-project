          <datasource-dependencies datasource='federated.1jhb71e13n5ckb1dtna3h0ayni8v'>
            <column caption='其他行为名称' datatype='string' name='[Calculation_1147854979518152716]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [F1]&#13;&#10;WHEN 1 THEN &quot;点击数&quot;&#13;&#10;WHEN 2 THEN &quot;点赞数&quot;&#13;&#10;WHEN 3 THEN &quot;收藏数&quot;&#13;&#10;WHEN 4 THEN &quot;购买数&quot;&#13;&#10;ELSE NULL&#13;&#10;END' />
            </column>
            <column caption='每小时行为次数' datatype='integer' name='[Calculation_1147854979526447118]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [F2],[F1]: SUM([F3])}' />
            </column>
            <column caption='每小时其他行为合计次数' datatype='integer' name='[Calculation_1147854979526561807]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [F2]: SUM(IF [F1] IN (2,3,4) THEN [F3] END)}' />
            </column>
            <column caption='其他行为占比' datatype='real' name='[Calculation_1147854979526635536]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [F1] IN (2,3,4) AND  [Calculation_1147854979526561807]&gt; 0&#13;&#10;THEN [Calculation_1147854979526447118] / [Calculation_1147854979526561807]&#13;&#10;ELSE NULL&#13;&#10;END' />
            </column>
            <column caption='行为' datatype='integer' name='[F1]' role='measure' type='quantitative' />
            <column caption='小时' datatype='integer' name='[F2]' role='measure' type='quantitative' />
            <column caption='次数' datatype='integer' name='[F3]' role='measure' type='quantitative' />
