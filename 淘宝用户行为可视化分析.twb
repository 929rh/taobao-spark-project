            <column-instance column='[行为 (复制)_1147854979512045574]' derivation='User' name='[usr:行为 (复制)_1147854979512045574:qk]' pivot='key' type='quantitative' />
            <column caption='点击数' datatype='integer' name='[行为 (复制)_1147854979512045574]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [F1] = 1 THEN [F3] END)' />
            </column>
            <column datatype='string' name='[行为 (组)]' role='dimension' type='nominal'>
              <calculation class='categorical-bin' column='[F1]' new-bin='true'>
